flowchart LR

  subgraph SL["Sensing Layer"]
    direction TB
    RPI["Raspberry Pi\nRPI 4B / Zero W"]

    subgraph SENSORS["Capteurs et Sources"]
      direction TB
      PIR["Capteur de presence\nPIR / infrarouge"]
      RFID["RFID simule\nN-BaIoT / CICIDS"]
    end

    DC["Collecte de donnees\nfreq. configurable"]
    EMEAS["Consommation\nmesure en mAh"]
    INTERP1["Interpretation\nseuil activite / pattern presence"]

    RPI --> SENSORS
    SENSORS --> DC
    DC --> EMEAS
    EMEAS --> INTERP1
  end

  subgraph NL["Network Layer"]
    direction TB

    subgraph STRATS["Strategies de transmission"]
      direction TB
      S1["S1 - Immediate\nchaque mesure envoyee"]
      S2["S2 - Agregation\nN donnees groupees"]
      S3["S3 - Sur anomalie\ndeclenchement conditionnel"]
    end

    NMETRICS["Metriques reseau\nlatence · bande passante · mAh"]
    INTERP2["Interpretation\ncout/benefice · overhead vs reactivite"]

    STRATS --> NMETRICS
    NMETRICS --> INTERP2
  end

  subgraph DPL["Data Processing Layer - Edge AI"]
    direction TB
    PROC["Traitement embarque\nRaspberry Pi Edge"]

    subgraph MODELS["Modeles legers ML"]
      direction LR
      THR["Thresholding\nregle fixe"]
      LR_M["Regression\nlogistique"]
      DT["Arbre de\ndecision"]
    end

    METRICS["Evaluation\nprecision · RAM · inference · mAh"]
    INTERP3["Interpretation\naccuracy vs footprint · energie/precision"]

    PROC --> MODELS
    MODELS --> METRICS
    METRICS --> INTERP3
  end

  subgraph AL["Application Layer"]
    direction TB
    DASH["Dashboard local\nGrafana / Flask"]
    VIZ["Visualisation\ncourbes · heatmaps"]
    ALERTS["Alertes automatiques\nemail · MQTT · SMS"]
    REPORT["Generation rapport\nPDF / CSV export"]

    DASH --> VIZ
    DASH --> ALERTS
    DASH --> REPORT
  end

  INTERP1 -- "flux brut horodate" --> S1
  INTERP1 -- "buffer N echantillons" --> S2
  INTERP1 -- "anomalie detectee" --> S3

  S1 -- "latence ~10ms / bw elevee" --> PROC
  S2 -- "latence ~500ms / bw optimisee" --> PROC
  S3 -- "latence ~50ms / bw minimale" --> PROC

  INTERP3 -- "label · score classifie" --> DASH

